<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "EventVenue",
  "name": "L'800 Locanda a Palazzo",
  "description": "Ristorante e location per eventi speciali ad Amantea: matrimoni intimi, comunioni, cresime, compleanni, anniversari. Cucina di pesce calabrese d'eccellenza in un palazzo storico dell'Ottocento.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Via Calavecchia 53",
    "addressLocality": "Amantea",
    "addressRegion": "CS",
    "postalCode": "87032",
    "addressCountry": "IT"
  },
  "telephone": "+390982428262",
  "url": "https://l800.netlify.app/eventi.html",
  "hasMap": "https://maps.app.goo.gl/ba6KmbiKwBSDKLZ2A"
}
</script>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Cormorant+SC:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5EFE4; --cream-light: #FAF6EF; --cream-dark: #EDE4D4;
    --brown: #7A4E28; --brown-dark: #5C3515; --brown-light: #A67C52;
    --brown-pale: #C4A882; --text: #3D2810; --text-light: #7A5C3C;
    --border: rgba(122,78,40,0.18);
  }
  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
  html, body { overflow-x:hidden; scroll-behavior:smooth; }
  img { max-width:100%; height:auto; }
  body { font-family:'EB Garamond',Georgia,serif; background:var(--cream-light); color:var(--text); }

  /* NAV */
  nav { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:16px 48px; background:rgba(250,246,239,0.96); backdrop-filter:blur(12px); border-bottom:1px solid var(--border); }
  .nav-logo { text-decoration:none; display:flex; flex-direction:column; line-height:1; }
  .nav-logo-main { font-family:'Cormorant Garamond',serif; font-style:italic; font-size:26px; color:var(--brown); }
  .nav-logo-sub { font-family:'Cormorant SC',serif; font-size:8px; letter-spacing:0.25em; color:var(--brown-light); text-transform:uppercase; }
  .nav-back { font-family:'Cormorant SC',serif; font-size:10px; letter-spacing:0.18em; color:var(--text-light); text-decoration:none; text-transform:uppercase; }
  .nav-back:hover { color:var(--brown); }

  /* HERO */
  .hero { padding:140px 80px 80px; background:var(--brown-dark); position:relative; overflow:hidden; }
  .hero::before { content:''; position:absolute; inset:0; background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23FAF6EF' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E"); pointer-events:none; }
  .hero-inner { position:relative; z-index:2; max-width:700px; }
  .hero-eyebrow { font-family:'Cormorant SC',serif; font-size:10px; letter-spacing:0.3em; color:var(--brown-pale); text-transform:uppercase; margin-bottom:20px; display:block; }
  .hero-title { font-family:'Cormorant Garamond',serif; font-size:clamp(38px,5.5vw,68px); font-weight:300; color:var(--cream-light); line-height:1.06; margin-bottom:28px; }
  .hero-title em { font-style:italic; color:var(--brown-pale); }
  .hero-sub { font-family:'EB Garamond',serif; font-style:italic; font-size:18px; color:rgba(245,239,228,0.72); line-height:1.75; max-width:560px; }

  /* INTRO */
  .intro { padding:80px; background:var(--cream-light); display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
  .intro-text { max-width:540px; }
  .section-label { font-family:'Cormorant SC',serif; font-size:10px; letter-spacing:0.28em; color:var(--brown-light); text-transform:uppercase; display:block; margin-bottom:14px; }
  .section-title { font-family:'Cormorant Garamond',serif; font-size:clamp(30px,4vw,48px); font-weight:300; line-height:1.1; color:var(--text); margin-bottom:24px; }
  .section-title em { font-style:italic; color:var(--brown); }
  .section-text { font-family:'EB Garamond',serif; font-size:16px; line-height:1.85; color:var(--text-light); margin-bottom:16px; }
  .ornament-line { width:40px; height:1px; background:var(--brown-pale); margin:24px 0; }
  .intro-features { list-style:none; display:flex; flex-direction:column; gap:12px; }
  .intro-features li { font-family:'EB Garamond',serif; font-size:15px; color:var(--text-light); display:flex; align-items:flex-start; gap:12px; line-height:1.5; }
  .intro-features li::before { content:'✦'; color:var(--brown-pale); font-size:9px; margin-top:5px; flex-shrink:0; }

  /* EVENTI GRID */
  .eventi-section { padding:80px; background:var(--cream-dark); }
  .eventi-header { text-align:center; margin-bottom:60px; }
  .eventi-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:2px; max-width:1100px; margin:0 auto 16px; }
  .evento-card { background:var(--cream-light); padding:40px 32px; transition:background 0.3s; }
  .evento-card:hover { background:var(--cream); }
  .evento-icon { font-size:28px; margin-bottom:16px; display:block; }
  .evento-nome { font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:400; color:var(--text); margin-bottom:10px; }
  .evento-desc { font-family:'EB Garamond',serif; font-style:italic; font-size:14px; color:var(--text-light); line-height:1.7; }
  .evento-seo { font-family:'Cormorant SC',serif; font-size:8px; letter-spacing:0.15em; color:var(--brown-pale); text-transform:uppercase; margin-top:10px; display:block; }

  /* SPAZI */
  .spazi-section { padding:80px; background:var(--cream-light); }
  .spazi-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; max-width:900px; margin:40px auto 0; }
  .spazio-card { border:1px solid var(--border); padding:36px 32px; }
  .spazio-titolo { font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--text); margin-bottom:6px; }
  .spazio-sottotitolo { font-family:'Cormorant SC',serif; font-size:9px; letter-spacing:0.18em; color:var(--brown-light); text-transform:uppercase; margin-bottom:14px; display:block; }
  .spazio-desc { font-family:'EB Garamond',serif; font-size:15px; font-style:italic; color:var(--text-light); line-height:1.7; }

  /* CTA */
  .cta-section { background:var(--brown); padding:80px; text-align:center; position:relative; overflow:hidden; }
  .cta-section::before { content:''; position:absolute; inset:0; background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23FAF6EF' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E"); pointer-events:none; }
  .cta-inner { position:relative; z-index:2; max-width:580px; margin:0 auto; }
  .cta-title { font-family:'Cormorant Garamond',serif; font-size:clamp(30px,4vw,46px); font-weight:300; color:var(--cream-light); margin-bottom:16px; line-height:1.1; }
  .cta-title em { font-style:italic; }
  .cta-sub { font-family:'EB Garamond',serif; font-style:italic; font-size:17px; color:rgba(245,239,228,0.7); line-height:1.7; margin-bottom:36px; }
  .btn-light { font-family:'Cormorant SC',serif; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:var(--brown); background:var(--cream-light); border:none; padding:14px 32px; cursor:pointer; text-decoration:none; transition:all 0.3s; display:inline-block; }
  .btn-light:hover { background:var(--cream-dark); }
  .btn-wa { font-family:'Cormorant SC',serif; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:#fff; background:#2e7d32; border:none; padding:14px 32px; cursor:pointer; text-decoration:none; transition:all 0.3s; display:inline-block; margin-left:14px; }
  .btn-wa:hover { background:#1b5e20; }

  /* FOOTER */
  footer { background:var(--brown-dark); padding:28px 48px; display:flex; align-items:center; justify-content:space-between; }
  .footer-brand { font-family:'Cormorant Garamond',serif; font-style:italic; font-size:22px; color:var(--cream-light); }
  .footer-copy { font-family:'Cormorant SC',serif; font-size:8px; letter-spacing:0.16em; color:rgba(245,239,228,0.35); text-transform:uppercase; }

  /* FADE IN */
  .fade-in { opacity:0; transform:translateY(20px); transition:opacity 0.7s ease, transform 0.7s ease; }
  .fade-in.visible { opacity:1; transform:translateY(0); }
  .delay-1 { transition-delay:0.1s; } .delay-2 { transition-delay:0.2s; } .delay-3 { transition-delay:0.3s; }

  /* RESPONSIVE */

  @media (max-width:1024px) {
    nav { padding:14px 32px; }
    .hero { padding:110px 48px 70px; }
    .intro { padding:64px 48px; grid-template-columns:1fr; gap:40px; }
    .eventi-section { padding:64px 48px; }
    .eventi-grid { grid-template-columns:1fr 1fr; }
    .spazi-section { padding:64px 48px; }
    .cta-section { padding:64px 48px; }
    footer { padding:24px 40px; }
  }

  @media(max-width:768px) {
    nav { padding:14px 20px; }
    .hero { padding:96px 24px 60px; }
    .intro { padding:56px 24px; grid-template-columns:1fr; gap:40px; }
    .eventi-section { padding:56px 24px; }
    .eventi-grid { grid-template-columns:1fr; gap:2px; }
    .spazi-section { padding:56px 24px; }
    .spazi-grid { grid-template-columns:1fr; }
    .cta-section { padding:56px 24px; }
    .btn-wa { margin-left:0; margin-top:12px; display:block; }
    footer { padding:20px; flex-direction:column; gap:10px; text-align:center; }
  }

  @media (max-width:400px) {
    .hero-title { font-size:30px; }
    .section-title { font-size:26px; }
    .capitolo-anno-val { font-size:26px; }
  }
</style>
</head>
<body>

<nav>
  <a href="index.html" class="nav-logo">
    <span class="nav-logo-main">L'800</span>
    <span class="nav-logo-sub">Locanda a Palazzo</span>
  </a>
  <a href="index.html" class="nav-back">← Torna al sito</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <span class="hero-eyebrow">Occasioni Speciali · Amantea · Calabria</span>
    <h1 class="hero-title">
      Il posto giusto<br>
      per i momenti<br>
      <em>che non dimentichi.</em>
    </h1>
    <p class="hero-sub">
      Matrimoni intimi, comunioni, cresime, compleanni, anniversari e ricevimenti privati.
      L'800 Locanda a Palazzo ad Amantea è la cornice ideale per rendere ogni cerimonia un ricordo indelebile.
    </p>
  </div>
</section>

<!-- INTRO -->
<section class="intro">
  <div class="intro-text fade-in">
    <span class="section-label">Perché sceglierci</span>
    <h2 class="section-title">
      Un palazzo storico,<br>
      una cucina <em>d'eccellenza</em>
    </h2>
    <p class="section-text">
      Organizzare un evento speciale ad Amantea significa scegliere il luogo giusto. L'800 Locanda a Palazzo offre un contesto unico: le sale di un palazzo dell'Ottocento nel cuore del centro storico, un giardino privato (in primavera e in estate) e una cucina di pesce calabrese che non delude.
    </p>
    <p class="section-text">
      Ogni evento è pensato su misura. Nessun pacchetto preconfezionato: ci racconti l'occasione, noi costruiamo l'esperienza.
    </p>
    <div class="ornament-line"></div>
    <ul class="intro-features">
      <li>Menu personalizzati in base all'occasione e alle preferenze</li>
      <li>Spazi dedicati per gruppi da 10 a 60 persone</li>
      <li>Cucina di pesce fresco del Tirreno, prodotti calabresi d'eccellenza</li>
      <li>Giardino storico disponibile per eventi all'aperto (primavera/estate)</li>
      <li>Supporto nella pianificazione dell'evento</li>
    </ul>
  </div>
  <div class="fade-in delay-1" style="background:var(--cream-dark);border:1px solid var(--border);height:420px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;">
    <span style="font-family:'Cormorant SC',serif;font-size:9px;letter-spacing:0.2em;color:var(--brown-pale);text-transform:uppercase;">📷 Foto da inserire</span>
    <span style="font-family:'EB Garamond',serif;font-style:italic;font-size:14px;color:var(--brown-pale);">Sala o giardino durante un evento</span>
  </div>
</section>

<!-- EVENTI GRID -->
<section class="eventi-section">
  <div class="eventi-header fade-in">
    <span class="section-label">Le nostre occasioni speciali</span>
    <h2 class="section-title">Per ogni <em>momento importante</em></h2>
  </div>

  <div class="eventi-grid">
    <div class="evento-card fade-in">
      <span class="evento-icon">💍</span>
      <h3 class="evento-nome">Matrimonio intimo</h3>
      <p class="evento-desc">
        Per chi sceglie l'eleganza discreta al posto della grandiosità. Un matrimonio intimo ad Amantea, con i sapori del mare calabrese e l'atmosfera raccolta di un palazzo storico.
      </p>
      <span class="evento-seo">Ristorante matrimoni Amantea · Wedding Calabria</span>
    </div>
    <div class="evento-card fade-in delay-1">
      <span class="evento-icon">🕊️</span>
      <h3 class="evento-nome">Comunione</h3>
      <p class="evento-desc">
        Un pranzo di comunione speciale, con menu pensati per grandi e piccoli. Un'occasione per far vivere un momento di festa autentico nel cuore di Amantea.
      </p>
      <span class="evento-seo">Ristorante comunione Amantea · Pranzo prima comunione</span>
    </div>
    <div class="evento-card fade-in delay-2">
      <span class="evento-icon">✝️</span>
      <h3 class="evento-nome">Cresima</h3>
      <p class="evento-desc">
        Festeggia la cresima con un pranzo di qualità. Menu calabresi autentici, ambiente elegante, cucina di pesce fresco per una cerimonia ad Amantea da ricordare.
      </p>
      <span class="evento-seo">Ristorante cresima Amantea · Pranzo cresima Calabria</span>
    </div>
    <div class="evento-card fade-in">
      <span class="evento-icon">🎂</span>
      <h3 class="evento-nome">Compleanno</h3>
      <p class="evento-desc">
        Dai un sapore speciale al tuo compleanno o a quello di chi ami. Un tavolo riservato, un menu su misura, la cucina di mare che rende ogni cena un'esperienza.
      </p>
      <span class="evento-seo">Ristorante compleanno Amantea · Cena compleanno Calabria</span>
    </div>
    <div class="evento-card fade-in delay-1">
      <span class="evento-icon">🥂</span>
      <h3 class="evento-nome">Anniversario</h3>
      <p class="evento-desc">
        Una cena romantica o un pranzo con la famiglia per festeggiare un anniversario importante. Il giardino storico dell'L'800 crea un'atmosfera irripetibile.
      </p>
      <span class="evento-seo">Ristorante anniversario Amantea · Cena romantica Calabria</span>
    </div>
    <div class="evento-card fade-in delay-2">
      <span class="evento-icon">💼</span>
      <h3 class="evento-nome">Pranzo di lavoro</h3>
      <p class="evento-desc">
        Colpisci i tuoi ospiti con una location d'eccellenza. Pranzi di lavoro e ricevimenti privati ad Amantea, in un contesto che unisce eleganza e autenticità calabrese.
      </p>
      <span class="evento-seo">Pranzo lavoro Amantea · Business lunch Calabria</span>
    </div>
  </div>
</section>

<!-- SPAZI -->
<section class="spazi-section">
  <div style="text-align:center;margin-bottom:12px;" class="fade-in">
    <span class="section-label">I nostri spazi</span>
    <h2 class="section-title">Dove si svolge <em>il tuo evento</em></h2>
  </div>
  <div class="spazi-grid">
    <div class="spazio-card fade-in">
      <span class="evento-icon">🏛</span>
      <h3 class="spazio-titolo">Le sale del palazzo</h3>
      <span class="spazio-sottotitolo">Tutto l'anno</span>
      <p class="spazio-desc">Le sale storiche dell'Ottocento, con soffitti alti, pareti a calce e l'atmosfera austera dell'architettura storica di Amantea. Ideali per cerimonie invernali e primaverili.</p>
    </div>
    <div class="spazio-card fade-in delay-1">
      <span class="evento-icon">🌿</span>
      <h3 class="spazio-titolo">Il giardino storico</h3>
      <span class="spazio-sottotitolo">Primavera e Estate</span>
      <p class="spazio-desc">Un angolo di verde nel cuore del centro storico di Amantea. Luci soffuse, vegetazione rigogliosa, atmosfera raccolta. La scelta ideale per matrimoni e cerimonie estive all'aperto.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-inner fade-in">
    <h2 class="cta-title">Raccontaci <em>la tua occasione</em></h2>
    <p class="cta-sub">
      Ogni evento è una storia diversa. Contattaci su WhatsApp o per email: ti risponderemo entro 24 ore con una proposta su misura per te.
    </p>
    <a href="https://wa.me/390982428262?text=Ciao%2C%20vorrei%20informazioni%20per%20organizzare%20un%20evento%20privato%20da%20L%27800." target="_blank" rel="noopener" class="btn-wa">📱 Scrivici su WhatsApp</a>
    <a href="mailto:info@l800.it" class="btn-light">oppure via email</a>
  </div>
</section>

<footer>
  <span class="footer-brand">L'800</span>
  <span class="footer-copy">© 2025 L'800 – Locanda a Palazzo · P.IVA 03906130780 · Via Calavecchia 53, Amantea (CS)</span>
</footer>

<script>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
</body>
</html>

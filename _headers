/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Immagini: cache lunga (cambiano raramente — cache bust con nome file se aggiorni)
/*.jpg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.jpeg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.png
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/*.webp
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# PDF menu: cache media (si aggiornano stagionalmente)
/*.pdf
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Font e manifest: cache lunga
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=86400

# HTML: cache corta (contenuto dinamico, aggiornabile)
/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=300

# API: mai in cache
/send-voucher
  Cache-Control: no-store
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type
